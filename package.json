{
  "name": "multivibe",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build:api": "tsc -p tsconfig.json",
    "build:web": "npm --prefix web run build",
    "build": "npm run build:web && npm run build:api",
    "start": "node dist/server.js",
    "test": "node --test --test-force-exit test/*.test.js",
    "test:coverage": "c8 --check-coverage --lines 50 --functions 60 --branches 60 --statements 50 node --test --test-force-exit test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:dead-code": "knip --include files,dependencies,unlisted --no-config-hints",
    "check:duplicates": "jscpd --config jscpd.json",
    "check:tech-debt": "node scripts/check-tech-debt.mjs",
    "docs:generate": "node scripts/generate-config-reference.mjs",
    "docs:check": "node scripts/generate-config-reference.mjs --check",
    "monitor:health": "node scripts/monitor-health.mjs",
    "validate:agents": "node scripts/validate-agent-docs.mjs",
    "validate": "npm run lint && npm run format:check && npm run build && npm run test:coverage && npm run check:dead-code && npm run check:duplicates && npm run check:tech-debt && npm run validate:agents",
    "prepare": "husky"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.0.5",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2"
  }
}
